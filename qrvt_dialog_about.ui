     <item>
      <widget class="QTextBrowser" name="textBrowser">
       <property name="html">
        <string>&lt;!DOCTYPE HTML PUBLIC &quot;-//W3C//DTD HTML 4.0//EN&quot; &quot;http://www.w3.org/TR/REC-html40/strict.dtd&quot;&gt;
&lt;html&gt;&lt;head&gt;&lt;meta name=&quot;qrichtext&quot; content=&quot;1&quot; /&gt;&lt;style type=&quot;text/css&quot;&gt;
p, li { white-space: pre-wrap; }
&lt;/style&gt;&lt;/head&gt;&lt;body style=&quot; font-family:'MS Shell Dlg 2'; font-size:8pt; font-weight:400; font-style:normal;&quot;&gt;
&lt;p style=&quot; margin-top:4px; margin-bottom:4px; margin-left:0px; margin-right:0px; -qt-block-indent:0; text-indent:0px;&quot;&gt;&lt;span style=&quot; font-family:'Segoe UI'; font-size:9pt; font-weight:600;&quot;&gt;Authors:&lt;/span&gt;&lt;span style=&quot; font-family:'Segoe UI'; font-size:9pt;&quot;&gt; Žiga Kokalj, Krištof Oštir, Klemen Zakšek, Peter Pehani, Klemen Čotar, Maja Somrak, Žiga Maroh, Nejc Čož &lt;/span&gt;&lt;/p&gt;
&lt;p style=&quot; margin-top:8px; margin-bottom:4px; margin-left:0px; margin-right:0px; -qt-block-indent:0; text-indent:0px;&quot;&gt;&lt;span style=&quot; font-family:'Segoe UI'; font-size:9pt; font-weight:600;&quot;&gt;You are encouraged to cite:&lt;/span&gt;&lt;span style=&quot; font-family:'Segoe UI'; font-size:9pt;&quot;&gt; &lt;/span&gt;&lt;/p&gt;
&lt;ul style=&quot;margin-top: 0px; margin-bottom: 0px; margin-left: 0px; margin-right: 0px; -qt-list-indent: 1;&quot;&gt;&lt;li style=&quot; font-family:'Segoe UI'; font-size:9pt;&quot; style=&quot; margin-top:0px; margin-bottom:2px; margin-left:0px; margin-right:0px; -qt-block-indent:0; text-indent:0px;&quot;&gt;Kokalj, Ž. 2025. &lt;span style=&quot; font-style:italic;&quot;&gt;Standardizing visualization in ancient Maya lidar research: Techniques, challenges and recommendations.&lt;/span&gt; Archaeological Prospection, 32(4), 967–988. DOI: &lt;a href=&quot;https://doi.org/10.1002/arp.70002&quot;&gt;&lt;span style=&quot; text-decoration: underline; color:#f3c6af;&quot;&gt;10.1002/arp.70002&lt;/span&gt;&lt;/a&gt; &lt;/li&gt;
&lt;li style=&quot; font-family:'Segoe UI'; font-size:9pt;&quot; style=&quot; margin-top:0px; margin-bottom:4px; margin-left:0px; margin-right:0px; -qt-block-indent:0; text-indent:0px;&quot;&gt;Zakšek, K., Oštir, K., Kokalj, Ž. 2011. &lt;span style=&quot; font-style:italic;&quot;&gt;Sky-view factor as a relief visualization technique.&lt;/span&gt; Remote Sensing 3, 398–415. DOI: &lt;a href=&quot;https://doi.org/10.3390/rs3020398&quot;&gt;&lt;span style=&quot; text-decoration: underline; color:#f3c6af;&quot;&gt;10.3390/rs3020398&lt;/span&gt;&lt;/a&gt; &lt;/li&gt;&lt;/ul&gt;
&lt;p style=&quot; margin-top:8px; margin-bottom:4px; margin-left:0px; margin-right:0px; -qt-block-indent:0; text-indent:0px;&quot;&gt;&lt;span style=&quot; font-family:'Segoe UI'; font-size:9pt; font-weight:600;&quot;&gt;Online resources:&lt;/span&gt;&lt;span style=&quot; font-family:'Segoe UI'; font-size:9pt;&quot;&gt; &lt;/span&gt;&lt;a href=&quot;https://rvt-py.readthedocs.io/en/latest/rvtfor_qgis.html&quot;&gt;&lt;span style=&quot; font-family:'Segoe UI'; font-size:9pt; text-decoration: underline; color:#f3c6af;&quot;&gt;documentation&lt;/span&gt;&lt;/a&gt;&lt;span style=&quot; font-family:'Segoe UI'; font-size:9pt;&quot;&gt;, &lt;/span&gt;&lt;a href=&quot;https://github.com/EarthObservation/rvt-qgis&quot;&gt;&lt;span style=&quot; font-family:'Segoe UI'; font-size:9pt; text-decoration: underline; color:#f3c6af;&quot;&gt;plugin ource code&lt;/span&gt;&lt;/a&gt;&lt;span style=&quot; font-family:'Segoe UI'; font-size:9pt;&quot;&gt;, &lt;/span&gt;&lt;a href=&quot;https://github.com/EarthObservation/RVT_py&quot;&gt;&lt;span style=&quot; font-family:'Segoe UI'; font-size:9pt; text-decoration: underline; color:#f3c6af;&quot;&gt;rvt_py (core library)&lt;/span&gt;&lt;/a&gt;&lt;span style=&quot; font-family:'Segoe UI'; font-size:9pt;&quot;&gt;, &lt;/span&gt;&lt;a href=&quot;https://github.com/EarthObservation/rvt-arcgis-pro&quot;&gt;&lt;span style=&quot; font-family:'Segoe UI'; font-size:9pt; text-decoration: underline; color:#f3c6af;&quot;&gt;ArcGIS Pro raster functions&lt;/span&gt;&lt;/a&gt;&lt;span style=&quot; font-family:'Segoe UI'; font-size:9pt;&quot;&gt;.&lt;/span&gt;&lt;/p&gt;
&lt;p style=&quot; margin-top:8px; margin-bottom:4px; margin-left:0px; margin-right:0px; -qt-block-indent:0; text-indent:0px;&quot;&gt;&lt;span style=&quot; font-family:'Segoe UI'; font-size:9pt; font-weight:600;&quot;&gt;Acknowledgments:&lt;/span&gt;&lt;span style=&quot; font-family:'Segoe UI'; font-size:9pt;&quot;&gt; &lt;/span&gt;&lt;/p&gt;
&lt;ul style=&quot;margin-top: 0px; margin-bottom: 0px; margin-left: 0px; margin-right: 0px; -qt-list-indent: 1;&quot;&gt;&lt;li style=&quot; font-family:'Segoe UI'; font-size:9pt;&quot; style=&quot; margin-top:0px; margin-bottom:2px; margin-left:0px; margin-right:0px; -qt-block-indent:0; text-indent:0px;&quot;&gt;Development of RVT Python scripts was part financed by the Slovenian Research Agency core funding No. P2-0406 and by research project No. J6-9395. &lt;/li&gt;
&lt;li style=&quot; font-family:'Segoe UI'; font-size:9pt;&quot; style=&quot; margin-top:0px; margin-bottom:4px; margin-left:0px; margin-right:0px; -qt-block-indent:0; text-indent:0px;&quot;&gt;Development of RVT QGIS plugin was part financed by PTS Consultancy via the UK Government Culture Recovery Fund. &lt;/li&gt;&lt;/ul&gt;
&lt;p style=&quot; margin-top:8px; margin-bottom:4px; margin-left:0px; margin-right:0px; -qt-block-indent:0; text-indent:0px;&quot;&gt;&lt;span style=&quot; font-size:9pt;&quot;&gt;Licensed under the Apache License, &lt;/span&gt;&lt;a href=&quot;http://www.apache.org/licenses/LICENSE-2.0&quot;&gt;&lt;span style=&quot; text-decoration: underline; color:#0000ff;&quot;&gt;Version 2.0&lt;/span&gt;&lt;/a&gt;&lt;span style=&quot; font-size:9pt;&quot;&gt;.&lt;/span&gt;&lt;/p&gt;
